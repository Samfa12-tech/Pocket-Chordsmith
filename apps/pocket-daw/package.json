{
  "name": "pocket-daw",
  "version": "0.6.26",
  "description": "Free Windows desktop arrangement and production app for Pocket Chordsmith projects, built with Vite, TypeScript, Tauri, and native audio playback.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samfa12-tech/Pocket-Chordsmith.git",
    "directory": "apps/pocket-daw"
  },
  "keywords": [
    "pocket-daw",
    "pocket-audio",
    "music-composition",
    "songwriting",
    "adaptive-music",
    "game-audio",
    "midi",
    "wav",
    "tauri"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5177 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "mcp:pocket-daw": "tsx src/mcp/pocketDawMcpServer.ts",
    "generate:native-sound-recipes": "node scripts/generate-native-sound-recipes.mjs",
    "verify:native-sound-recipes": "node scripts/generate-native-sound-recipes.mjs --check",
    "package:preview": "npm run build && node scripts/package-preview.mjs",
    "release:updater-manifest": "node scripts/make-updater-manifest.mjs",
    "verify:versions": "node scripts/verify-versions.mjs",
    "status:release": "node scripts/render-release-status.mjs",
    "verify:smoke-attestation": "node scripts/verify-smoke-attestation.mjs",
    "package:itch": "node scripts/package-itch.mjs",
    "verify:artifacts": "node scripts/verify-release-artifacts.mjs",
    "verify:itch": "node scripts/verify-itch.mjs",
    "package:itch-bootstrapper": "node scripts/package-itch-bootstrapper.mjs",
    "verify:itch-bootstrapper": "node scripts/verify-itch-bootstrapper.mjs",
    "release:itch:local": "npm run verify:itch",
    "itch:preview": "butler push-preview releases/itch/installers samfa12/pocket-daw:windows-installer",
    "itch:push": "node scripts/guarded-butler-push.mjs",
    "itch:push:hidden": "node scripts/guarded-butler-push.mjs",
    "itch:push:bootstrapper": "node scripts/guarded-butler-push-bootstrapper.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:native-release": "node scripts/verify-release.mjs --native-release",
    "release:update": "node scripts/release-updater-build.mjs",
    "release:update:fast": "node scripts/release-updater-build.mjs --fast",
    "release:update:full": "node scripts/release-updater-build.mjs --full",
    "release:update:publish": "node scripts/release-updater-build.mjs --full --publish",
    "signing:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/with-tauri-signing-env.ps1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:debug": "tauri build --debug --no-bundle",
    "tauri:build:installers": "tauri build --config src-tauri/tauri.package.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:signed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/with-tauri-signing-env.ps1 npx tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.9.3",
    "adm-zip": "^0.5.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  }
}
