{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Samfa12-tech/Pocket-Chordsmith/apps/pocket-daw/releases/smoke-attestation.schema.json",
  "title": "Pocket DAW exact-artifact smoke attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "commit",
    "installerFile",
    "installerSha256",
    "testedAt",
    "result",
    "machine",
    "checks",
    "knownFailures"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{40}$"
    },
    "installerFile": {
      "type": "string",
      "minLength": 1
    },
    "installerSha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "testedAt": {
      "anyOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    },
    "result": {
      "const": "pass"
    },
    "machine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "windowsVersion",
        "architecture",
        "audioInput",
        "audioOutput"
      ],
      "properties": {
        "windowsVersion": {
          "type": "string",
          "minLength": 1
        },
        "architecture": {
          "type": "string",
          "minLength": 1
        },
        "audioInput": {
          "type": "string",
          "minLength": 1
        },
        "audioOutput": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "result"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": [
              "pass",
              "fail",
              "partial"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "knownFailures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
